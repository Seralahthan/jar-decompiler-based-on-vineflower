# Docker build/run configuration
# Copy this file to .env and adjust values for your environment

# CPU architecture: linux/amd64 or linux/arm64
PLATFORM=linux/arm64

# Host port to access the app (http://localhost:<HOST_PORT>)
HOST_PORT=9090

# Resource limits for the container
MEM_LIMIT=6g
CPUS=4

# Redis connection URL
REDIS_URL=redis://redis:6379/0

# Gunicorn workers and threads (per worker)
GUNICORN_WORKERS=4
GUNICORN_THREADS=4

# Thread pool sizes (per Gunicorn worker)
# Full JAR decompile + indexing jobs (-Xmx2g each)
FULL_DECOMPILE_POOL_SIZE=4
# Per-class decompile jobs (-Xmx256m each)
CLASS_DECOMPILE_POOL_SIZE=20
